# ── JWT ──────────────────────────────────────────────────────
# Generate a real key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./secure_messenger.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/secure_messenger

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Blockchain (Sepolia testnet) ──────────────────────────────
# Get a free RPC URL from Alchemy or Infura
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Private key of the deployer / recorder wallet (no 0x prefix)
DEPLOYER_PRIVATE_KEY=your-deployer-private-key-here
# Set this after running: npm run deploy:sepolia inside blockchain/
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere
