# ── JWT ──────────────────────────────────────────────────────
# Generate a real key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./secure_messenger.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/secure_messenger

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── Blockchain (Sepolia testnet) ──────────────────────────────
# Get a free RPC URL from Alchemy or Infura (or use a public node)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Private key of the deployer / recorder wallet (no 0x prefix). This wallet is
# the KeyRegistry registrar and MessageReceipt server — the only account
# allowed to register/rotate/revoke keys and post receipts.
DEPLOYER_PRIVATE_KEY=your-deployer-private-key-here

# Deployed contract addresses. The values below are the live Sepolia
# deployment (see docs/deployment.md); override only if you redeploy.
# MessageDigest (pre-existing digest-anchoring contract):
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere
# KeyRegistry (on-chain key transparency log):
KEY_REGISTRY_ADDRESS=0x230c56Ab59535625c8eAeF18f8394b7D222a889D
# MessageReceipt (signed inclusion receipts):
MESSAGE_RECEIPT_ADDRESS=0x355557d9E5bd1188372986f3ad73b60D992Ef9e5
